<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us — Digismartz Technologies</title>
  <meta name="description" content="Contact Digismartz Technologies for a free digital marketing consultation. Call, WhatsApp, or send us a message.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Manrope:wght@400;500;700&family=Space+Mono&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="assets/img/favicon.png">
  <meta name="theme-color" content="#07080C">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

<header class="site-header">
  <div class="container nav">
    <a class="logo" href="index.html" aria-label="Digismartz Technologies — Home">
      <img src="assets/img/digismartz-logo.png" alt="Digismartz Technologies — Transforming Ideas into Digital Success" width="1468" height="378">
    </a>
    <nav class="nav-links" id="navLinks">
      <a href="index.html">Home</a>
      <a href="about.html">About</a>
      <a href="services.html">Services</a>
      <a href="portfolio.html">Portfolio</a>
      <a href="contact.html" class="active">Contact</a>
      <a href="contact.html#consult" class="btn btn-primary">Free Consultation</a>
    </nav>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="navLinks"><span></span></button>
  </div>
</header>

<main>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Let's talk about <span class='accent'>your growth</span></h1>
      <p class="lead">Book a free consultation, request a quote, or just say hello — we reply within one business day.</p>
    </div>
    <svg class="signal" viewBox="0 0 1440 46" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 23 H180 L200 8 L220 38 L240 23 H420 L440 15 L460 31 L480 23 H700 L720 4 L740 42 L760 23 H980 L1000 12 L1020 34 L1040 23 H1240 L1260 16 L1280 30 L1300 23 H1440"/>
    </svg>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <div class="reveal">
        <h2 style="margin-bottom:1.6rem">Get in touch</h2>
        <div class="info-line"><div class="icon">📞</div><div><b>Phone</b><a href="tel:+919087572428">+91 90875 72428</a></div></div>
        <div class="info-line"><div class="icon">💬</div><div><b>WhatsApp</b><a href="https://wa.me/919087572428" target="_blank" rel="noopener">Chat with us instantly</a></div></div>
        <div class="info-line"><div class="icon">✉️</div><div><b>Email</b><span>Coming soon</span></div></div>
        <div class="info-line"><div class="icon">📍</div><div><b>Office</b><span>Digismartz Technologies,<br>Palayamkottai, Tirunelveli,<br>Tamil Nadu, India.</span></div></div>
        <div class="info-line"><div class="icon">🕒</div><div><b>Hours</b><span>Mon–Sat · 9:30 AM – 7:00 PM IST</span></div></div>
        <div class="hero-cta" style="margin-top:1.6rem">
          <a href="https://wa.me/919087572428" class="btn btn-whatsapp" target="_blank" rel="noopener">WhatsApp Us</a>
          <a href="tel:+919087572428" class="btn btn-ghost">Call Now</a>
        </div>
      </div>

      <div class="card reveal" id="consult">
        <p class="eyebrow">Free consultation</p>
        <h3 style="margin-top:0">Tell us about your project</h3>
        <p style="margin-bottom:1.4rem">Fill in the form and we'll get back to you within one business day with a clear next step.</p>
        <form id="contactForm" action="https://formspree.io/f/xvzeavjp" method="POST" data-formspree novalidate>
          <input type="hidden" name="_subject" value="New enquiry — Digismartz Technologies website">
          <input type="text" name="_gotcha" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true">
          <div class="form-grid">
            <div><label for="name">Full name *</label><input id="name" name="name" type="text" required placeholder="Your full name" autocomplete="name"></div>
            <div><label for="email">Email address *</label><input id="email" name="email" type="email" required placeholder="you@company.com" autocomplete="email"></div>
            <div><label for="phone">Phone number *</label><input id="phone" name="phone" type="tel" required placeholder="+91 XXXXX XXXXX" autocomplete="tel"></div>
            <div><label for="company">Company name <em class="optional">(optional)</em></label><input id="company" name="company" type="text" placeholder="Your company" autocomplete="organization"></div>
            <div class="full"><label for="service">Service required *</label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Select a service…</option>
                <option>Website Development</option>
                <option>Digital Marketing</option>
                <option>Branding &amp; Identity Design</option>
                <option>SEO Services</option>
                <option>Social Media Marketing</option>
                <option>Performance Marketing</option>
                <option>Other</option>
              </select>
            </div>
            <div class="full"><label for="message">Message *</label><textarea id="message" name="message" required placeholder="Tell us about your business and what you'd like to achieve…"></textarea></div>
          </div>
          <button class="btn btn-primary" type="submit" style="margin-top:1.2rem">Send Enquiry →</button>
          <p class="form-note">We respect your privacy — your details are only used to respond to your enquiry.</p>
          <div class="form-success" role="status">✅ Thank you for contacting Digismartz Technologies! We have received your enquiry and will get back to you shortly.</div>
          <div class="form-error" role="alert">⚠️ Something went wrong while sending your message. Please try again, or reach us directly on WhatsApp or phone.</div>
        </form>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Location</p>
        <h2>Find us</h2>
        <p>Digismartz Technologies · Palayamkottai, Tirunelveli, Tamil Nadu, India.</p>
      </div>
      <div class="map-embed reveal">
        <iframe src="https://www.google.com/maps?q=Palayamkottai,+Tirunelveli,+Tamil+Nadu,+India&output=embed" title="Digismartz Technologies location — Palayamkottai, Tirunelveli" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container reveal">
      <h2>Let's build your digital success story.</h2>
      <p>Book a free consultation and get a clear, honest roadmap for your brand — no obligations.</p>
      <div class="hero-cta" style="justify-content:center">
        <a href="contact.html#consult" class="btn btn-primary">Get a Free Consultation</a>
        <a href="https://wa.me/919087572428" class="btn btn-whatsapp" target="_blank" rel="noopener">WhatsApp Us</a>
      </div>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a class="logo logo-footer" href="index.html" aria-label="Digismartz Technologies — Home">
          <img src="assets/img/digismartz-logo.png" alt="Digismartz Technologies" width="1468" height="378" loading="lazy">
        </a>
        <p style="margin-top:1rem">Transforming Ideas into Digital Success. Full-service digital marketing, branding, and creative technology services.</p>
        <div class="socials">
          <a href="#" aria-label="Facebook">f</a>
          <a href="#" aria-label="Instagram">◎</a>
          <a href="#" aria-label="LinkedIn">in</a>
          <a href="#" aria-label="YouTube">▶</a>
          <a href="#" aria-label="X (Twitter)">𝕏</a>
        </div>
        <p class="footer-address">📍 Digismartz Technologies,<br>Palayamkottai, Tirunelveli,<br>Tamil Nadu, India.</p>
      </div>
      <div>
        <h4>Company</h4>
        <ul>
          <li><a href="about.html">About Us</a></li>
          <li><a href="portfolio.html">Portfolio</a></li>
          <li><a href="contact.html">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Services</h4>
        <ul>
          <li><a href="services.html">Digital Marketing</a></li>
          <li><a href="services.html">SEO &amp; SEM</a></li>
          <li><a href="services.html">Branding</a></li>
          <li><a href="services.html">Web Development</a></li>
          <li><a href="services.html">Google &amp; Meta Ads</a></li>
        </ul>
      </div>
      <div>
        <h4>Stay in the loop</h4>
        <p>Get practical digital marketing tips in your inbox.</p>
        <form class="newsletter" data-demo style="margin-top:1rem">
          <input type="email" placeholder="Your email address" required aria-label="Email address">
          <button class="btn btn-primary" type="submit">Subscribe</button>
          <div class="form-success">Subscribed — welcome aboard!</div>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© <span data-year></span> Digismartz Technologies. All rights reserved.</span>
      <span>📞 <a href="tel:+919087572428">+91 90875 72428</a></span>
    </div>
  </div>
</footer>

<div class="fab-stack">
  <a class="fab fab-wa" href="https://wa.me/919087572428" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">💬</a>
  <a class="fab fab-call" href="tel:+919087572428" aria-label="Call us">📞</a>
</div>

<script src="js/main.js"></script>
</body>
</html>
